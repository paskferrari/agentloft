{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentLoft",
  "version": "0.1.0",
  "identifier": "com.providencestudioweb.agentloft",
  "build": {
    "frontendDist": "http://localhost:3200",
    "devUrl": "http://localhost:3200",
    "beforeDevCommand": "node ../../dist/cli.js --port 3200"
  },
  "app": {
    "windows": [
      {
        "title": "AgentLoft",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true,
        "backgroundColor": "#0f0e17"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3200 ws://localhost:3200; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dist/cli.js": "cli.js",
      "../../dist/assets": "assets",
      "../../dist/hooks": "hooks",
      "../../dist/webview": "webview"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
